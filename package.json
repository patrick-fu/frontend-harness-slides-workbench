{
  "name": "frontend-harness-slides-workbench",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "homepage": "https://frontend-harness-slides-workbench.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/patrick-fu/frontend-harness-slides-workbench.git"
  },
  "bugs": {
    "url": "https://github.com/patrick-fu/frontend-harness-slides-workbench/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:audit": "playwright test",
    "typecheck": "tsc --noEmit",
    "generate:catalog": "node scripts/publication/cli.mjs manifest",
    "generate:showcase-thumbnails": "node scripts/publication/cli.mjs capture",
    "clean:showcase-thumbnails": "node scripts/publication/cli.mjs clean",
    "verify:showcase-thumbnails": "node scripts/publication/cli.mjs verify",
    "ci": "npm run typecheck && npm run build && npm run test:unit && npm run verify:showcase-thumbnails"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.1.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.2"
  }
}
